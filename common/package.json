{
  "name": "citadels-common",
  "version": "0.0.1",
  "description": "Online Citadels board game (common)",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npx tsc -p tsconfig.build.json",
    "lint": "npx eslint --ext .ts --ignore-path .gitignore . --fix",
    "test": "vitest run"
  },
  "repository": "https://github.com/antbrl/citadels-online",
  "author": "Antoine Brûlé",
  "license": "MIT",
  "dependencies": {
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^4.19.0",
    "eslint-config-airbnb-typescript": "^12.3.1",
    "vitest": "^4.1.10"
  }
}
