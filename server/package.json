{
  "name": "citadels-server",
  "version": "0.0.1",
  "description": "Online Citadels board game (server)",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build --prefix ../common && npx tsc",
    "start": "npm run build && node dist/index.js",
    "start:prod": "node dist/index.js",
    "start:debug": "npm run build && DEBUG=citadels-server node --inspect dist/index.js",
    "lint": "npx eslint --ext .ts --ignore-path .gitignore . --fix",
    "typecheck": "npx tsc --noEmit",
    "test": "npm run build --prefix ../common && vitest run"
  },
  "repository": "https://github.com/antbrl/citadels-online",
  "author": "Antoine Brûlé",
  "license": "MIT",
  "dependencies": {
    "@types/connect-history-api-fallback": "^1.3.5",
    "@types/debug": "^4.1.6",
    "@types/express": "^4.17.11",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "citadels-common": "file:../common",
    "connect-history-api-fallback": "^1.6.0",
    "debug": "^4.3.2",
    "express": "^4.17.1",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^3.1.22",
    "nanoid-dictionary": "^4.2.0",
    "socket.io": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/socket.io": "^2.1.13",
    "@typescript-eslint/eslint-plugin": "^4.19.0",
    "eslint-config-airbnb-typescript": "^12.3.1",
    "eslint-plugin-import": "^2.22.1",
    "tslint": "^6.1.3",
    "typescript": "6.0.3",
    "vitest": "^4.1.10"
  }
}
