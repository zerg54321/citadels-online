{
  "extends": [
    "airbnb-typescript/base"
  ],
  "parserOptions": {
    "project": "./tsconfig.json"
  },
  "ignorePatterns": [
    "vitest.config.ts",
    "dist/"
  ],
  "rules": {
    "no-console": 0,
    "lines-between-class-members": "off",
    "@typescript-eslint/lines-between-class-members": [
      "off"
    ],
    "no-shadow": "off",
    "@typescript-eslint/no-shadow": "error",
    "import/prefer-default-export": "off"
  }
}